{
    "name": "exedeck",
    "version": "1.0.0",
    "description": "A secure cross-platform workspace for running and monitoring development processes.",
    "license": "ISC",
    "author": {
        "name": "avendor",
        "email": "avendor@example.com"
    },
    "type": "module",
    "main": "out/main/main.js",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:a11y": "npm run build && node scripts/accessibility-smoke.mjs",
        "check": "npm run typecheck && npm test && npm run build",
        "build": "electron-vite build",
        "pack": "npm run build && electron-builder --dir",
        "dist": "npm run build && electron-builder",
        "dist:win": "npm run build && electron-builder --win nsis",
        "dist:linux": "npm run build && electron-builder --linux AppImage deb",
        "smoke": "cross-env SMOKE=1 electron .",
        "start": "electron .",
        "start:linux": "electron ."
    },
    "devDependencies": {
        "@types/node": "^25.3",
        "@vitejs/plugin-vue": "^6.0.4",
        "axe-core": "^4.12.1",
        "cross-env": "^10.1.0",
        "electron": "^40.10.6",
        "electron-builder": "^26.8.1",
        "electron-vite": "^5.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.10",
        "ws": "^8.21.0"
    },
    "dependencies": {
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0",
        "node-pty": "^1.1.0",
        "pidusage": "^4.0.1",
        "tree-kill": "^1.2.2",
        "vue": "^3.5"
    },
    "build": {
        "appId": "com.exedeck.app",
        "productName": "Exedeck",
        "directories": {
            "buildResources": "build",
            "output": "release"
        },
        "files": [
            "out/**/*",
            "node_modules/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "build/icon.png",
                "to": "build/icon.png"
            },
            {
                "from": "build/icon.ico",
                "to": "build/icon.ico"
            }
        ],
        "asar": true,
        "asarUnpack": [
            "**/*.node"
        ],
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "icon.ico"
        },
        "linux": {
            "target": [
                "AppImage",
                "deb"
            ],
            "icon": "icon.png",
            "category": "Development",
            "maintainer": "avendor <avendor@example.com>"
        }
    },
    "allowScripts": {
        "electron@40.10.6": true,
        "esbuild@0.25.12": true,
        "esbuild@0.28.1": true,
        "node-pty@1.1.0": true,
        "electron-winstaller@5.4.0": true
    }
}
